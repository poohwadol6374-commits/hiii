generator client {
  provider   = "prisma-client-js"
  output     = "../node_modules/.prisma/client"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

// ==================== Enums ====================

enum AuthProvider {
  email
  google
}

enum Locale {
  th
  en
}

enum TaskPriority {
  high
  medium
  low
}

enum TaskStatus {
  pending
  in_progress
  completed
  cancelled
}

enum EnergyLevel {
  high
  medium
  low
}

enum CalendarEventType {
  task
  meeting
  focus_time
  break_time
  personal
  blocked
}

enum Theme {
  light
  dark
  auto
}

enum CalendarView {
  day
  week
  month
}

enum AIAggressiveness {
  conservative
  balanced
  proactive
}

enum LumaPersonality {
  formal
  friendly
  cheerful
  motivational
  minimal
}

enum AnimationLevel {
  full
  reduced
  none
}

enum TaskCreationMode {
  modal
  drawer
  inline
}

enum SharePermission {
  read
  edit
}

enum GoalTargetType {
  weekly
  monthly
}

enum GoalStatus {
  active
  completed
  failed
}

enum AttachmentType {
  image
  pdf
  link
  other
}

enum ChatRole {
  user
  luma
}

enum ReminderType {
  notification
  email
}

// ==================== Models ====================

model User {
  id                     String    @id @default(uuid()) @db.Uuid
  email                  String    @unique
  name                   String
  passwordHash           String?
  avatarUrl              String?
  authProvider           AuthProvider @default(email)
  locale                 Locale    @default(th)
  hasCompletedOnboarding Boolean   @default(false)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  tasks              Task[]
  taskCategories     TaskCategory[]
  calendarEvents     CalendarEvent[]
  preferences        UserPreferences?
  aiRecommendations  AIRecommendation[]
  scheduleSnapshots  ScheduleSnapshot[]
  goals              Goal[]
  templates          Template[]
  chatMessages       ChatMessage[]
  behavior           UserBehavior?
  ownedShares        CalendarShare[]   @relation("CalendarOwner")
  receivedShares     CalendarShare[]   @relation("SharedWith")

  @@index([email])
}

model Task {
  id                String       @id @default(uuid()) @db.Uuid
  userId            String       @db.Uuid
  title             String       @db.VarChar(500)
  description       String?
  categoryId        String?      @db.Uuid
  priority          TaskPriority @default(medium)
  priorityScore     Float        @default(0)
  status            TaskStatus   @default(pending)
  deadline          DateTime?
  estimatedDuration Int?
  scheduledStart    DateTime?
  scheduledEnd      DateTime?
  isRecurring       Boolean      @default(false)
  recurrenceRule    String?
  tags              Json         @default("[]")
  energyLevel       EnergyLevel  @default(medium)
  colorCode         String?      @db.VarChar(7)
  notes             String?
  templateId        String?      @db.Uuid
  projectId         String?      @db.Uuid
  parentTaskId      String?      @db.Uuid
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  category      TaskCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  template      Template?     @relation(fields: [templateId], references: [id], onDelete: SetNull)
  parentTask    Task?         @relation("TaskSubtasks", fields: [parentTaskId], references: [id], onDelete: SetNull)
  subtasks      Task[]        @relation("TaskSubtasks")
  attachments   Attachment[]
  reminders     Reminder[]
  calendarEvent CalendarEvent?

  @@index([userId])
  @@index([status])
  @@index([deadline])
  @@index([scheduledStart])
  @@index([userId, status])
  @@index([userId, deadline])
}


model TaskCategory {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @db.Uuid
  name      String
  icon      String
  color     String   @db.VarChar(7)
  isPreset  Boolean  @default(false)
  createdAt DateTime @default(now())

  user  User?  @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([userId])
  @@index([isPreset])
}

model CalendarEvent {
  id             String            @id @default(uuid()) @db.Uuid
  userId         String            @db.Uuid
  title          String
  type           CalendarEventType
  startTime      DateTime
  endTime        DateTime
  isAllDay       Boolean           @default(false)
  color          String?           @db.VarChar(7)
  isRecurring    Boolean           @default(false)
  recurrenceRule String?
  location       String?
  relatedTaskId  String?           @unique @db.Uuid
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  user        User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  relatedTask Task? @relation(fields: [relatedTaskId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([startTime])
  @@index([userId, startTime])
}

model UserPreferences {
  id                    String            @id @default(uuid()) @db.Uuid
  userId                String            @unique @db.Uuid
  workingHoursStart     String            @default("09:00") @db.VarChar(5)
  workingHoursEnd       String            @default("18:00") @db.VarChar(5)
  peakEnergyStart       String            @default("09:00") @db.VarChar(5)
  peakEnergyEnd         String            @default("12:00") @db.VarChar(5)
  lowEnergyStart        String            @default("14:00") @db.VarChar(5)
  lowEnergyEnd          String            @default("15:00") @db.VarChar(5)
  preferredBreakDuration Int              @default(15)
  breakFrequency        Int               @default(90)
  focusBlockMinDuration Int               @default(25)
  focusBlockMaxDuration Int               @default(90)
  timezone              String            @default("Asia/Bangkok")
  theme                 Theme             @default(light)
  customThemeColor      String?           @db.VarChar(7)
  defaultCalendarView   CalendarView      @default(week)
  aiAggressiveness      AIAggressiveness  @default(balanced)
  lumaPersonality       LumaPersonality   @default(friendly)
  locale                Locale            @default(th)
  taskCreationMode      TaskCreationMode  @default(modal)
  sidebarCollapsed      Boolean           @default(false)
  animationLevel        AnimationLevel    @default(full)
  pomodoroWorkDuration  Int               @default(25)
  pomodoroBreakDuration Int               @default(5)
  notifyInApp           Boolean           @default(true)
  notifyEmail           Boolean           @default(true)
  notifyPush            Boolean           @default(false)
  notifyLumaProactive   Boolean           @default(true)
  quietHoursStart       String?           @db.VarChar(5)
  quietHoursEnd         String?           @db.VarChar(5)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AIRecommendation {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid
  type            String
  title           String
  description     String
  reasoning       String
  relatedTaskIds  Json     @default("[]")
  suggestedAction Json?
  confidence      Float    @default(0)
  isActioned      Boolean  @default(false)
  lumaMood        String   @default("neutral")
  createdAt       DateTime @default(now())
  expiresAt       DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isActioned])
}

model ScheduleSnapshot {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  snapshotDate DateTime
  events       Json
  tasks        Json
  reason       String
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, snapshotDate])
}

model Attachment {
  id         String         @id @default(uuid()) @db.Uuid
  taskId     String         @db.Uuid
  type       AttachmentType
  fileName   String
  fileUrl    String
  fileSize   Int
  mimeType   String
  uploadedAt DateTime       @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model CalendarShare {
  id                String          @id @default(uuid()) @db.Uuid
  calendarOwnerId   String          @db.Uuid
  sharedWithUserId  String          @db.Uuid
  permission        SharePermission
  createdAt         DateTime        @default(now())
  expiresAt         DateTime?

  calendarOwner User @relation("CalendarOwner", fields: [calendarOwnerId], references: [id], onDelete: Cascade)
  sharedWith    User @relation("SharedWith", fields: [sharedWithUserId], references: [id], onDelete: Cascade)

  @@unique([calendarOwnerId, sharedWithUserId])
  @@index([calendarOwnerId])
  @@index([sharedWithUserId])
}

model Goal {
  id                String         @id @default(uuid()) @db.Uuid
  userId            String         @db.Uuid
  title             String
  description       String?
  targetType        GoalTargetType
  targetValue       Float
  currentValue      Float          @default(0)
  unit              String
  relatedCategoryId String?        @db.Uuid
  startDate         DateTime
  endDate           DateTime
  status            GoalStatus     @default(active)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
}

model Template {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String?  @db.Uuid
  name         String
  description  String?
  taskDefaults Json
  isPreset     Boolean  @default(false)
  usageCount   Int      @default(0)
  createdAt    DateTime @default(now())

  user  User?  @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([userId])
  @@index([isPreset])
}

model ChatMessage {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @db.Uuid
  role          ChatRole
  content       String
  intent        String?
  actionPayload Json?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
}

model UserBehavior {
  id                 String   @id @default(uuid()) @db.Uuid
  userId             String   @unique @db.Uuid
  categoryTimeMap    Json     @default("{}")
  completionPatterns Json     @default("[]")
  energyPatterns     Json     @default("[]")
  actualPeakHours    Json     @default("[]")
  actualLowHours     Json     @default("[]")
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Reminder {
  id           String       @id @default(uuid()) @db.Uuid
  taskId       String       @db.Uuid
  reminderTime DateTime
  type         ReminderType @default(notification)
  isSent       Boolean      @default(false)
  createdAt    DateTime     @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([reminderTime, isSent])
}
